# Copy to .env for local dev. Never commit the real .env.

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Local dev uses SQLite by default (nothing to set).
# To use PostgreSQL locally instead, set a connection string:
# DATABASE_URL=postgres://user:password@localhost:5432/lms
# On Render, DATABASE_URL is injected automatically from the managed database.

# --- CORS / CSRF (frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=

# --- Production only (set on Render; ignored when DEBUG=True) ---
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-service.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_HSTS_SECONDS=31536000
